rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isManager() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isReportCreator(reportId) {
      return firestore.get(/databases/(default)/documents/reports/$(reportId)).data.createdBy == request.auth.uid;
    }

    // Report attachments: any authenticated user can read
    // Only the report's creator, admin, or manager can write/delete
    match /reports/{reportId}/attachments/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10 MB max
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf')
        && (isReportCreator(reportId) || isAdmin() || isManager());
      allow delete: if request.auth != null
        && (isReportCreator(reportId) || isAdmin() || isManager());
    }
  }
}
