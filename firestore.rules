rules_version = '2';

service cloud.firestore {
  match /databases/sydenham-asc/documents {

    // Helper: is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the user an admin?
    function isAdmin() {
      return isAuth() &&
        get(/databases/sydenham-asc/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: is the user a tutor?
    function isTutor() {
      return isAuth() &&
        get(/databases/sydenham-asc/documents/users/$(request.auth.uid)).data.role == 'tutor';
    }

    // ── Users Collection ────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    // ── Students Collection ────────────────────────────────────
    match /students/{studentId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Reports Collection ─────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isTutor() || isAdmin());
      allow update: if isAuth() && (
        (resource.data.createdBy == request.auth.uid &&
          resource.data.status in ['draft', 'rejected']) ||
        isAdmin()
      );
      allow delete: if isAdmin() && resource.data.status == 'draft';
    }
  }
}
