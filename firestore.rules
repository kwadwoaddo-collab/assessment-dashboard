rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the request authenticated? ────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Safe role lookup (returns '' if doc doesn't exist) ───────
    function userRole() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAdmin()   { return userRole() == 'admin'; }
    function isManager() { return userRole() == 'manager'; }
    function isTutor()   { return userRole() == 'tutor'; }
    function isStaff()   { return isAdmin() || isManager() || isTutor(); }

    // ── Users Collection ─────────────────────────────────────────
    // Anyone can read their own profile.
    // Admins & managers can read all users (needed for tutor lists).
    match /users/{userId} {
      allow read:   if isAuth() && (request.auth.uid == userId || isAdmin() || isManager());
      allow create: if isAdmin();
      allow update: if isAuth() && (
        isAdmin() || 
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.email == resource.data.email &&
         (resource.data.active == null || request.resource.data.active == resource.data.active))
      );
      allow delete: if false;
    }

    // ── Students Collection ──────────────────────────────────────
    // Any authenticated staff member can read students.
    // Only admins & managers can create/update/deactivate students.
    match /students/{studentId} {
      allow read:          if isAuth() && isStaff();
      allow create, update: if isAdmin() || isManager();
      allow delete:        if false;
    }

    // ── Reports Collection ───────────────────────────────────────
    // All staff can read all reports.
    // Tutors can create reports.
    // Tutors can update their OWN draft/rejected reports.
    // Admins & managers can update any report (approve/reject/edit).
    // Only admins can delete draft reports.
    match /reports/{reportId} {
      allow read:   if isAuth() && isStaff();
      allow create: if isAuth() && 
        (isTutor() || isAdmin() || isManager()) && 
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status in ['draft', 'submitted'];
      allow update: if isAuth() && (
        isAdmin() ||
        isManager() ||
        (resource.data.createdBy == request.auth.uid &&
         resource.data.status in ['draft', 'rejected'] &&
         request.resource.data.createdBy == resource.data.createdBy &&
         request.resource.data.status in ['draft', 'submitted'])
      );
      allow delete: if isAuth() && (isAdmin() || isManager() || resource.data.createdBy == request.auth.uid) && resource.data.status == 'draft';
    }

    // ── Cash Receipts Collection ─────────────────────────────────
    match /cash_receipts/{receiptId} {
      allow read, create, update: if isAuth() && isStaff();
      allow delete: if false;
    }
  }
}
